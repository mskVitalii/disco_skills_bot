# ── Telegram ──────────────────────────────────────────────────────────────────
BOT_TOKEN=7xxxxxxxxx:AAxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# Webhook URL для production. Оставь пустым для polling в dev.
WEBHOOK_URL=https://your-app.railway.app

# ID владельца бота — его сообщения игнорируются в бизнес-чатах (отвечает только на /disco)
BOT_OWNER_ID=

# ── Database ──────────────────────────────────────────────────────────────────
DATABASE_URL=postgres://disco_user:disco_pass@localhost:5432/disco_db

# ── Redis ─────────────────────────────────────────────────────────────────────
REDIS_URL=redis://localhost:6379

# ── OpenAI ────────────────────────────────────────────────────────────────────
OPENAI_API_KEY=sk-proj-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
OPENAI_MODEL=gpt-4o-mini

# Модель для расшифровки голосовых сообщений и кружочков
WHISPER_MODEL=whisper-1

# ── App ───────────────────────────────────────────────────────────────────────
DEBUG=false
# Максимальное число характеристик, отвечающих на одно сообщение
MAX_SKILL_RESPONSES=4
